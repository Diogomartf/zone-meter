{
  "expo": {
    "name": "Zone Meter",
    "slug": "zone-meter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zonemeter",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.diogomartf.zonemeter",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.diogomartf.zonemeter",
      "adaptiveIcon": {
        "backgroundColor": "#0053ED",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0290FC",
          "image": "./assets/images/splash.png",
          "resizeMode": "cover",
          "enableFullScreenImage_legacy": true,
          "ios": {
            "image": "./assets/images/splash.png",
            "backgroundColor": "#0290FC"
          },
          "android": {
            "image": "./assets/images/splash-android.png",
            "imageWidth": 240,
            "resizeMode": "contain",
            "backgroundColor": "#0290FC"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "83b55314-5d42-46ca-bc43-4bacc218e7d4"
      }
    }
  }
}
